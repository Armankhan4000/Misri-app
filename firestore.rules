rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // IMPORTANT: For development/preview sandbox compatibility where client-side Firebase Auth is not fully wired,
    // we allow read/write access. Ensure you secure this for production by enforcing the commented rules below.
    match /{document=**} {
      allow read, write: if true;
    }

    /*
    // SECURE PRODUCTION RULES (Uncomment and deploy once Firebase Auth / Google Sign-In is configured)
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if the user is Super Admin based on allowed runtime emails
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'armanhossain08102000@gmail.com' ||
        request.auth.token.email == 'armanhossain0810200@gmail.com'
      ) && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Customers Collection Rules
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(customerId) && (
        isAdmin() || (request.resource.data.id == customerId)
      );
      allow delete: if isAdmin();
    }

    // Technicians Collection Rules
    match /technicians/{techId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(techId) && (
        isAdmin() || (request.resource.data.id == techId)
      );
      allow delete: if isAdmin();
    }

    // Bookings Collection Rules
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.customerId == request.auth.uid ||
        resource.data.technicianId == request.auth.uid
      );
      allow create, update: if isSignedIn() && isValidId(bookingId) && (
        isAdmin() || 
        request.resource.data.customerId == request.auth.uid || 
        request.resource.data.technicianId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Banners Collection Rules
    match /banners/{bannerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Promo Codes Collection Rules
    match /promoCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Products Collection Rules
    match /products/{prodId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Orders Collection Rules
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        isAdmin() || resource.data.customerName == request.auth.token.email
      );
      allow create, update: if isSignedIn() && isValidId(orderId) && (
        isAdmin() || request.resource.data.customerName == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    // System Logs Collection Rules
    match /systemLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
    */
  }
}
